// panel
.panel_bg {
  background: built-in(ui-eco:BACKGROUND);
  padding-all: 5;
  gap-all: 4;
}

.panel_border, .__inventory_main__, .__inventory_hotbar__ {
  background: built-in(ui-eco:INVENTORY_BORDER);
}

// button
button:host {
  base-background: built-in(ui-eco:BUTTON);
  hover-background: built-in(ui-eco:BUTTON_HOVER);
  pressed-background: built-in(ui-eco:BUTTON_HIGHLIGHTED);
  padding-all: 3;
  height: 16;
}

button.__disabled__ .__button_text__ {
  text-color: #666;
  text-shadow: false;
}

// toggle
.__toggle_button__ {
  base-background: built-in(ui-eco:BUTTON);
  hover-background: built-in(ui-eco:BUTTON_HOVER);
  pressed-background: built-in(ui-eco:BUTTON_HIGHLIGHTED);
}

// slot
item-slot {
  background: built-in(ui-eco:ITEM_SLOT);
  hover-overlay: #A0daffff
}

pattern-item-slot {
  background: built-in(ui-eco:ITEM_SLOT);
  hover-overlay: #A0daffff
}

fluid-slot {
  background: built-in(ui-eco:ITEM_SLOT);
  hover-overlay: #A0daffff
}

// progress bar
.__progress-bar_bar-container__ {
  background: built-in(ui-eco:BAR_CONTAINER);
}

.__progress-bar_bar__ {
  background: built-in(ui-eco:BAR);
}

// unified ECO host UI
.eco-host-panel {
  background: built-in(ui-eco:BACKGROUND);
  padding-all: 6;
  gap-all: 5;
}

.eco-host-header {
  gap-all: 2;
}

.eco-host-toolbar {
  gap-all: 4;
}

.eco-host-card {
  background: built-in(ui-eco:HOST_PANEL_BORDER);
}

.eco-host-card {
  padding-all: 6;
  gap-all: 3;
}

.eco-computation-capacity {
  gap-all: 1;
}


.eco-host-progress .__progress-bar_bar-container__ {
  background: #1f2f3428;
}

.eco-host-progress .__progress-bar_bar__ {
  background: #26a6bd;
}

.eco-host-stats-progress {
  padding-all: 2;
  background: built-in(ui-eco:HOST_PANEL_BORDER);
}

.eco-host-stats-progress .__progress-bar_bar-container__ {
  padding-all: 1;
  background: #201e27;
}

.eco-host-stats-progress .__progress-bar_bar__ {
  background: #8377ff;
}

.eco-storage-load-inset-edge {
  background: #c9c3d6;
}

.eco-storage-load-inset-border {
  background: #17141e;
}

.eco-storage-load-inset-fill {
  background: #201e27;
}

.eco-host-panel-row {
  gap-all: 6;
}

.eco-host-bottom-row {
  gap-all: 8;
}

.eco-host-toolbar-button {
  padding-all: 0;
}

.eco-host-status-row {
  gap-all: 4;
}

.eco-host-status-light-edge {
  background: #d8d3e4;
}

.eco-host-status-light-border {
  background: #17141e;
}

.eco-host-status-light-on {
  background: #55ff8a;
}

.eco-host-status-light-off {
  background: #ff6a75;
}

.eco-host-gauge-row {
  gap-all: 14;
}

.eco-host-energy-gauge {
  padding-all: 3;
  background: built-in(ui-eco:HOST_PANEL_BORDER);
}

.eco-host-energy-gauge .__progress-bar_bar-container__ {
  padding-all: 1;
  background: #17141e;
}

.eco-host-energy-gauge .__progress-bar_bar__ {
  background: #00fc00;
}

.eco-host-energy-medium .__progress-bar_bar__ {
  background: #e7a943;
}

.eco-host-energy-warning .__progress-bar_bar__ {
  background: #ffd65a;
}

.eco-host-coolant-gauge {
  padding-all: 3;
  background: built-in(ui-eco:HOST_PANEL_BORDER);
}

.eco-host-task-panel {
  padding-all: 0;
}
