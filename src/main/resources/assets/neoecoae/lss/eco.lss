// panel
.panel_bg {
  background: built-in(ui-eco:BACKGROUND);
  padding-all: 5;
  gap-all: 4;
}

.panel_border, .__inventory_main__, .__inventory_hotbar__ {
  background: built-in(ui-eco:INVENTORY_BORDER);
}

// button
button:host {
  base-background: built-in(ui-eco:BUTTON);
  hover-background: built-in(ui-eco:BUTTON_HOVER);
  pressed-background: built-in(ui-eco:BUTTON_HIGHLIGHTED);
  padding-all: 3;
  height: 16;
}

button.__disabled__ .__button_text__ {
  text-color: #666;
  text-shadow: false;
}

// toggle
.__toggle_button__ {
  base-background: built-in(ui-eco:BUTTON);
  hover-background: built-in(ui-eco:BUTTON_HOVER);
  pressed-background: built-in(ui-eco:BUTTON_HIGHLIGHTED);
}

// slot
item-slot {
  background: built-in(ui-eco:ITEM_SLOT);
  hover-overlay: #A0daffff
}

pattern-item-slot {
  background: built-in(ui-eco:ITEM_SLOT);
  hover-overlay: #A0daffff
}

fluid-slot {
  background: built-in(ui-eco:ITEM_SLOT);
  hover-overlay: #A0daffff
}

// progress bar
.__progress-bar_bar-container__ {
  background: built-in(ui-eco:BAR_CONTAINER);
}

.__progress-bar_bar__ {
  background: built-in(ui-eco:BAR);
}

// unified ECO host UI
.eco-host-panel {
  background: built-in(ui-eco:BACKGROUND);
}

.eco-host-header {
  padding-bottom: 4;
}

.eco-host-status {
  background: #143c4620;
}

.eco-host-metric, .eco-host-card, .eco-host-tile {
  background: built-in(ui-eco:CARD_BACKGROUND);
}

.eco-host-scroll-port {
  background: #00000000;
}

.eco-host-card {
  padding-all: 6;
}

.eco-host-tile {
  padding-all: 5;
}

.eco-host-metric-spacer {
  background: #00000000;
}

.eco-host-progress .__progress-bar_bar-container__ {
  background: #1f2f3428;
}

.eco-host-progress .__progress-bar_bar__ {
  background: #26a6bd;
}

.eco-storage-load-inset-edge {
  background: #c9c3d6;
}

.eco-storage-load-inset-border {
  background: #17141e;
}

.eco-storage-load-inset-fill {
  background: #201e27;
}

.eco-host-footer {
  padding-top: 2;
}
